{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "google-scholar-semantic.config.schema.json",
  "title": "Google Scholar Semantic Runner Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "queries": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "query_file": {
      "type": "string"
    },
    "html": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "text": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "output_dir": {
      "type": "string"
    },
    "jsonl": {
      "type": "string"
    },
    "report": {
      "type": "string"
    },
    "domain": {
      "type": "string",
      "enum": ["general", "theology"],
      "default": "general"
    },
    "tre_expand": {
      "type": "boolean",
      "default": false
    },
    "no_expand": {
      "type": "boolean",
      "default": false
    },
    "tre_terms": {
      "type": "string"
    },
    "max_queries": {
      "type": "integer",
      "minimum": 1,
      "default": 12
    },
    "max_results": {
      "type": "integer",
      "minimum": 1,
      "default": 10
    },
    "max_queries_per_session": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4,
      "default": 4
    },
    "citation_depth": {
      "type": "string",
      "enum": ["all", "top5", "none"],
      "default": "all"
    },
    "wait_seconds": {
      "type": "integer",
      "minimum": 0,
      "default": 40
    },
    "headless": {
      "type": "boolean",
      "default": false
    }
  }
}
