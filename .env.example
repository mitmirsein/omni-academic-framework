# Default live LLM provider
# ANTHROPIC_API_KEY=your-api-key-here

# Live LLM 튜닝 (선택): 모델 오버라이드 / 응답 토큰 예산
# OMNI_LLM_MODEL=claude-opus-4-7
# OMNI_LLM_MAX_TOKENS=16000

# Reserved for future/alternate providers; not used by the default live path
# OPENAI_API_KEY=your-api-key-here
# GEMINI_API_KEY=your-api-key-here

# Recon and source-fetching APIs (optional)
# SEMANTIC_SCHOLAR_API_KEY=your-api-key-here
# SERPAPI_API_KEY=your-api-key-here
# JINA_API_KEY=your-api-key-here

# 외부 도구(External Tools) 경로 수동 설정 (미설정 시 시스템 PATH 자동 탐색)
# OMNI_LIGHTPANDA_BIN=/path/to/lightpanda
# OMNI_PDF_EXTRACTOR=/path/to/pdftotext
